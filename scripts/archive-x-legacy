#!/usr/bin/env bash
set -euo pipefail

repo_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_dir"

export UV_CACHE_DIR="${UV_CACHE_DIR:-/tmp/uv-cache}"
if [[ "${VIRTUAL_ENV:-}" != "" && "${VIRTUAL_ENV:-}" != "$repo_dir/.venv" ]]; then
    unset VIRTUAL_ENV
fi

exec uv run python scripts/archive_x_legacy.py "$@"
