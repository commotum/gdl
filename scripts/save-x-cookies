#!/usr/bin/env bash
set -euo pipefail

repo_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_dir"

export UV_CACHE_DIR="${UV_CACHE_DIR:-/tmp/uv-cache}"
if [[ "${VIRTUAL_ENV:-}" != "" && "${VIRTUAL_ENV:-}" != "$repo_dir/.venv" ]]; then
    unset VIRTUAL_ENV
fi

unlock_keyring=0
export GDL_UNLOCK_KEYRING="$unlock_keyring"

exec uv run python - "$@" <<'PY'
import argparse
import os
import platform
import sqlite3
import stat
import sys
import subprocess
import getpass
from pathlib import Path

try:
    import secretstorage
except Exception:
    secretstorage = None

from gallery_dl.cookies import load_cookies


repo = Path.cwd()
output = repo / "state" / "cookies" / "x.cookies.txt"
output.parent.mkdir(parents=True, exist_ok=True)

parser = argparse.ArgumentParser(
    description="Export X cookies from Chrome or the repo's Firefox profile",
)
parser.add_argument(
    "--browser",
    choices=("firefox", "chrome"),
    default="firefox",
    help="source browser (default: firefox)",
)
parser.add_argument(
    "--unlock-keyring",
    action="store_true",
    help="prompt to unlock GNOME Keyring before reading Chrome on Linux",
)
args = parser.parse_args()
unlock_keyring = args.unlock_keyring

wanted = {
    "auth_token",
    "ct0",
    "kdt",
    "twid",
    "guest_id",
    "guest_id_ads",
    "guest_id_marketing",
    "personalization_id",
}


def maybe_unlock_gnome_keyring():
    if platform.system() != "Linux":
        return

    if unlock_keyring:
        password = getpass.getpass("GNOME keyring password: ")
        try:
            proc = subprocess.run(
                ["gnome-keyring-daemon", "--unlock"],
                input=password + "\n",
                text=True,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                check=False,
            )
            if proc.returncode != 0:
                print("gnome-keyring-daemon --unlock failed")
                if proc.stderr:
                    print(proc.stderr.strip())
            else:
                print("Submitted unlock request to gnome-keyring-daemon.")
        finally:
            password = None

    if secretstorage is None:
        return
    try:
        con = secretstorage.dbus_init()
        try:
            col = secretstorage.get_default_collection(con)
            if col.is_locked():
                print("GNOME keyring is locked; requesting unlock prompt...")
                dismissed = col.unlock(timeout=60)
                if dismissed or col.is_locked():
                    print("GNOME keyring is still locked.")
        finally:
            con.close()
    except Exception as exc:
        print(f"GNOME keyring unlock check failed: {exc.__class__.__name__}: {exc}")


def raw_chrome_has_auth_token():
    if platform.system() == "Darwin":
        root = Path.home() / "Library" / "Application Support" / "Google" / "Chrome"
    else:
        root = Path.home() / ".config" / "google-chrome"

    found_database = False
    for db in root.rglob("Cookies") if root.exists() else ():
        try:
            con = sqlite3.connect("file:" + str(db) + "?mode=ro&immutable=1", uri=True)
            try:
                found_database = True
                row = con.execute(
                    "select count(*) from cookies "
                    "where host_key in ('.x.com', 'x.com') and name = 'auth_token'"
                ).fetchone()
                if row and row[0]:
                    return True
            finally:
                con.close()
        except Exception:
            continue
    return False if found_database else None


def load_spec(spec):
    try:
        return list(load_cookies(spec))
    except Exception as exc:
        print(f"{spec}: {exc.__class__.__name__}: {exc}")
        return []


def cookie_key(cookie):
    return (cookie.domain, cookie.path, cookie.name)


def netscape_line(cookie):
    domain = cookie.domain or ""
    if cookie.has_nonstandard_attr("HttpOnly") or cookie._rest.get("HttpOnly"):
        domain = "#HttpOnly_" + domain
    include_subdomains = "TRUE" if (cookie.domain or "").startswith(".") else "FALSE"
    path = cookie.path or "/"
    secure = "TRUE" if cookie.secure else "FALSE"
    expires = int(cookie.expires or 0)
    return "\t".join((
        domain,
        include_subdomains,
        path,
        secure,
        str(expires),
        cookie.name,
        cookie.value,
    ))


maybe_unlock_gnome_keyring()

if args.browser == "firefox":
    profile = str(repo / "state" / "firefox-x-profile")
    specs = [
        ("firefox", profile, None, None, ".x.com"),
        ("firefox", profile, None, None, ".twitter.com"),
    ]
else:
    keyrings = ("gnomekeyring", "kwallet", None) \
        if platform.system() == "Linux" else (None,)
    specs = [
        ("chrome", None, keyring, None, domain)
        for domain in (".x.com", ".twitter.com")
        for keyring in keyrings
    ]

cookies_by_key = {}
for spec in specs:
    cookies = load_spec(spec)
    names = sorted({cookie.name for cookie in cookies})
    print(f"{spec}: {len(cookies)} cookies; names={names}")
    for cookie in cookies:
        if cookie.name in wanted and cookie.value:
            cookies_by_key[cookie_key(cookie)] = cookie

names = sorted({cookie.name for cookie in cookies_by_key.values()})
if "auth_token" not in names:
    print("")
    print(f"Could not export a usable X auth_token from {args.browser.title()}.")
    if args.browser == "chrome":
        raw_has_auth = raw_chrome_has_auth_token()
        if raw_has_auth:
            print("Chrome's raw cookie DB contains auth_token, but it could not be decrypted.")
            print("Unlock the desktop keyring and rerun with --browser chrome.")
        else:
            print("Log into x.com in Chrome and rerun with --browser chrome.")
    else:
        print("Run scripts/open-x-firefox-login, log into X, close Firefox, and rerun.")
    sys.exit(1)

lines = [
    "# Netscape HTTP Cookie File",
    "# Generated by scripts/save-x-cookies. Keep this file private.",
]
for cookie in sorted(cookies_by_key.values(), key=lambda c: (c.domain, c.name)):
    lines.append(netscape_line(cookie))
lines.append("")

tmp = output.with_suffix(".tmp")
tmp.write_text("\n".join(lines))
os.chmod(tmp, stat.S_IRUSR | stat.S_IWUSR)
tmp.replace(output)

print("")
print(f"Saved {len(cookies_by_key)} X cookies to {output}")
print(f"Saved names: {names}")
PY
